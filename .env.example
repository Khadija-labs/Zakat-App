# ========== CONTACT FORM EMAIL (required for form to actually send) ==========
# Where contact form messages are delivered (your inbox)
MAIL_TO="your-email@gmail.com"

# Gmail: use the SAME Gmail account as MAIL_TO (your-email@gmail.com).
# You MUST create an "App Password" (not your normal password): Google Account → Security → 2-Step Verification → App passwords.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=""
SMTP_PASS="your-app-password"
# Optional: "From" name shown in inbox
MAIL_FROM=""

# ========== reCAPTCHA (optional, for contact form spam protection) ==========
# Get keys at https://www.google.com/recaptcha/admin (reCAPTCHA v2 "I'm not a robot").
# Frontend (Vite): use in client/.env or .env at project root with VITE_ prefix so the client can read it.
VITE_RECAPTCHA_SITE_KEY=your-recaptcha-site-key
# Backend: secret key for server-side verification (never expose this in the client).
RECAPTCHA_SECRET_KEY=your-recaptcha-secret-key

# ========== ZakatGPT (optional chatbot) ==========
# Get an API key at https://platform.openai.com/api-keys
# If not set, the ZakatGPT chat button still appears but the API will return a friendly error.
OPENAI_API_KEY=sk-your-openai-api-key

# ========== Calculator & chatbot defaults (optional; PKR and rates) ==========
# Default currency (calculator and chatbot use PKR).
VITE_DEFAULT_CURRENCY=PKR
# Gold rate in PKR per tola (1 tola = 11.6638 g). Calculator pre-fill and chatbot default.
VITE_DEFAULT_GOLD_RATE_PKR_PER_TOLA=522300
# Silver rate in PKR per tola. Used for Nisab (52.5 tolas). Calculator and chatbot.
VITE_DEFAULT_SILVER_RATE_PKR_PER_TOLA=11102
# Server-only fallbacks (if VITE_* not available to API): DEFAULT_CURRENCY=PKR, DEFAULT_GOLD_RATE_PKR_PER_TOLA=522300, DEFAULT_SILVER_RATE_PKR_PER_TOLA=11102